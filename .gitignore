# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/
/dev/

# production
/build

# misc
.DS_Store
/wireclaude.zip
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ignore claude and codex hidden directories
*.claude
*.codex

# python
.venv/
__pycache__/
*.pyc
.oats/runs/
.oats/pr-runs/
.oats-worktrees/

# generated database artifacts
/public/database-artifacts/
/public/database-schemas/
/var/
