{
  "name": "helaicopter",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:mobile": "HELA_WEB_HOST=0.0.0.0 HELA_API_HOST=0.0.0.0 HELA_USE_API_PROXY=1 node scripts/dev.mjs",
    "dev:web": "sh -c 'next dev --hostname \"${HELA_WEB_HOST:-127.0.0.1}\" --port \"${PORT:-3000}\"'",
    "api:dev": "sh -c 'uv run uvicorn helaicopter_api.server.main:app --host \"${HELA_API_HOST:-127.0.0.1}\" --port \"${HELA_API_PORT:-30000}\"'",
    "api:openapi": "uv run python scripts/generate-openapi-artifacts.py",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:refresh": "uv run python -m helaicopter_db.refresh --trigger cli",
    "db:migrate:oltp": "uv run alembic -x target=oltp upgrade head",
    "db:migrate:olap": "uv run alembic -x target=olap upgrade head",
    "db:export": "tsx scripts/export-parsed-data.ts",
    "cap:sync": "cap sync ios",
    "cap:open": "cap open ios",
    "cap:run": "cap run ios",
    "mobile:ios:sync": "sh -c ': \"${HELA_MOBILE_SERVER_URL:?Set HELA_MOBILE_SERVER_URL to http://your-mac-hostname:PORT}\"; cap sync ios'",
    "mobile:ios:open": "sh -c ': \"${HELA_MOBILE_SERVER_URL:?Set HELA_MOBILE_SERVER_URL to http://your-mac-hostname:PORT}\"; cap open ios'",
    "mobile:ios:run": "sh -c ': \"${HELA_MOBILE_SERVER_URL:?Set HELA_MOBILE_SERVER_URL to http://your-mac-hostname:PORT}\"; cap run ios'"
  },
  "dependencies": {
    "@capacitor/app": "^8.0.1",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@dagrejs/dagre": "^2.0.4",
    "@duckdb/duckdb-wasm": "^1.33.1-dev20.0",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/dagre": "^0.7.54",
    "@xyflow/react": "^12.10.1",
    "better-sqlite3": "^12.6.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.575.0",
    "next": "16.1.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "swr": "^2.4.0",
    "tailwind-merge": "^3.5.0",
    "tsx": "^4.21.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
